          "completion_model": "openai/gpt-4.1-mini"
        },
        "o3": {
          "target": "openai/o3",
          "reasoning_model": "openai/o3"
        }
      }
    },
    "openai": {
      "base_url": "https://api.openai.com",
      "api_key": "sk-...",
      "models": {
        "gpt-4.1": {},
        "gpt-4.1-mini": {},
        "gpt-4.1-nano": {},
