          "reasoning_model": "o3"
        },
        "o4-mini": {
          "reasoning_model": "o4-mini",
          "allow_failover": true
        }
      }
    },
    "ollama": {
      "base_url": "http://localhost:11434",
      "models": {
        "qwen3:32b": {
          "target": "qwen3:32b"
        },
        "devstral": {
          "target": "devstral",
          "allow_failover": true
        }
      }
    }
  }
}